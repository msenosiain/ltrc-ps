# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=3000
API_GLOBAL_PREFIX=/api/v1

# Comma-separated list of allowed origins (e.g. https://campo.lostordos.com.ar)
API_CORS_ALLOWED_ORIGINS=http://localhost:4200

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/ltrc-campo
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/ltrc-campo
MONGODB_URI=mongodb://localhost:27017/ltrc-campo

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AUTH_JWT_SECRET=change-me
AUTH_REFRESH_JWT_SECRET=change-me-too

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
GOOGLE_AUTH_ALLOWED_DOMAIN=lostordos.com.ar

# Local dev
# GOOGLE_AUTH_REDIRECT_URL=http://localhost:3000/api/v1/auth/google/redirect
# GOOGLE_AUTH_CALLBACK_URL=http://localhost:4200/auth/callback

# Production
# GOOGLE_AUTH_REDIRECT_URL=https://campo-be.lostordos.com.ar/api/v1/auth/google/redirect
# GOOGLE_AUTH_CALLBACK_URL=https://campo.lostordos.com.ar/auth/callback

# ── Mercado Pago ──────────────────────────────────────────────────────────────
# Obtener en https://www.mercadopago.com.ar/developers/panel/credentials
# TEST: usar credenciales de sandbox para pruebas
MP_ACCESS_TOKEN=TEST-xxxx-xxxx-xxxx-xxxx
# Comisión de Mercado Pago expresada como porcentaje (ej: 5 = 5%). Argentina: 3.99% + IVA 21% = 4.83%
MP_FEE_RATE=4.83
# URL base de la app Angular (para los back_urls de MP)
APP_BASE_URL=https://campo.lostordos.com.ar
