## Patrón: Servicio HTTP

```ts
// services/Players.service.ts
import { psApi } from '../lib/axios'
import type { Player, PlayersResponse, PlayersFilters } from '../domain/player'

export const PlayersService = {
  getAll: (filters: PlayersFilters) =>
    psApi.get<PlayersResponse>('/players', { params: filters }).then(r => r.data),

  getById: (id: string) =>
    psApi.get<Player>(`/players/${id}`).then(r => r.data),

  create: (data: FormData) =>
    psApi.post<Player>('/players', data).then(r => r.data),

  update: (id: string, data: FormData) =>
    psApi.patch<Player>(`/players/${id}`, data).then(r => r.data),

  remove: (id: string) =>
    psApi.delete(`/players/${id}`).then(r => r.data),
}
```

